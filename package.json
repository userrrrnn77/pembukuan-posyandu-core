{
  "name": "backend-posyandu-usm",
  "version": "1.0.0",
  "description": "Sistem Informasi Manajemen Posyandu Balita & Lansia - USM Edition",
  "main": "testing.ts",
  "type": "module",
  "author": "Chrisna Arjuna",
  "license": "USM",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "systemd-run --user --scope -p CPUQuota=40% -p MemoryMax=2G taskset -c 0-2 bun --watch testing.ts",
    "build": "systemd-run --user --scope -p CPUQuota=50% -p MemoryMax=3G tsc",
    "start": "node dist/index.js",
    "vercel-build": "tsc"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.5"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
